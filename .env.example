APP_NAME="Promafi ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=America/Mexico_City

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=tu_base_de_datos
DB_USERNAME=tu_usuario
DB_PASSWORD=tu_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=ventas@promafi.mx
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="ventas@promafi.mx"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Facturama SSL: si en producción aparece "cURL error 60: unable to get local issuer certificate",
# define CURL_CA_BUNDLE con el bundle del sistema (recomendado):
# CURL_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt
# (RHEL/CentOS) o /etc/ssl/certs/ca-certificates.crt (Debian/Ubuntu)
# Si no está definido, se intentan esas rutas automáticamente.
# Último recurso: CURL_CA_BUNDLE=false